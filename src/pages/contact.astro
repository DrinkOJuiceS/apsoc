---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with the UST Applied Physics Society.">
  <section class="bg-aps-black text-white py-16 px-4 text-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-serif text-4xl font-bold mb-3" data-animate="fade-up">Contact Us</h1>
      <p class="text-gray-400" data-animate="fade-up" data-animate-delay="120">Reach out for inquiries, membership, or collaboration</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div data-animate="fade-right">
          <h2 class="font-serif text-2xl font-bold text-aps-black mb-6">Get in Touch</h2>
          <div class="space-y-5 text-gray-600">
            <div>
              <p class="font-medium text-aps-black text-sm">Email</p>
              <p class="text-sm mt-0.5">your-email@ust.edu.ph</p>
            </div>
            <div>
              <p class="font-medium text-aps-black text-sm">Location</p>
              <p class="text-sm mt-0.5">University of Santo Tomas<br />España Blvd, Sampaloc, Manila</p>
            </div>
            <div>
              <p class="font-medium text-aps-black text-sm">Social Media</p>
              <div class="flex gap-4 mt-1.5">
                <a href="#" class="text-sm text-gold hover:underline transition-colors">Facebook</a>
                <a href="#" class="text-sm text-gold hover:underline transition-colors">Instagram</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div data-animate="fade-left">
          <h2 class="font-serif text-2xl font-bold text-aps-black mb-6">Send a Message</h2>
          <form name="contact" method="POST" data-netlify="true" class="space-y-4">
            <input type="hidden" name="form-name" value="contact" />
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1" for="name">Name</label>
              <input
                id="name" name="name" type="text" required
                class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:border-gold transition-colors text-sm"
                placeholder="Your name"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1" for="email">Email</label>
              <input
                id="email" name="email" type="email" required
                class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:border-gold transition-colors text-sm"
                placeholder="your@email.com"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1" for="subject">Subject</label>
              <select
                id="subject" name="subject"
                class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:border-gold transition-colors text-sm text-gray-700"
              >
                <option>General Inquiry</option>
                <option>Membership</option>
                <option>Research Collaboration</option>
                <option>Event Partnership</option>
                <option>Other</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1" for="message">Message</label>
              <textarea
                id="message" name="message" rows="4" required
                class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:border-gold transition-colors text-sm resize-none"
                placeholder="Your message..."
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full py-3 bg-gold text-aps-black font-semibold rounded-lg hover:bg-gold-dark transition-colors duration-200"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
