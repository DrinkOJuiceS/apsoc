---
import BaseLayout from '../layouts/BaseLayout.astro';
import researchGroups from '../data/research-groups.json';
---

<BaseLayout title="Research" description="Research groups affiliated with the UST Applied Physics Society.">
  <section class="bg-aps-black text-white py-16 px-4 text-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-serif text-4xl font-bold mb-3" data-animate="fade-up">Research Groups</h1>
      <p class="text-gray-400" data-animate="fade-up" data-animate-delay="120">Affiliated laboratories and research teams</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      {researchGroups.length === 0 ? (
        <div class="bg-gray-50 rounded-xl p-12 text-center border border-dashed border-gray-200" data-animate="fade-up">
          <p class="text-gray-400 mb-2">Research group links will be listed here.</p>
          <p class="text-gray-400 text-sm">Add entries to <code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs">src/data/research-groups.json</code></p>
        </div>
      ) : (
        <div class="grid gap-4">
          {researchGroups.map((group: any, i: number) => (
            <a
              href={group.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-start justify-between p-6 bg-white rounded-xl border border-gray-100 shadow-sm hover:border-gold hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 group"
              data-animate="fade-up"
              data-animate-delay={String(i * 80)}
            >
              <div>
                <h3 class="font-semibold text-aps-black group-hover:text-gold transition-colors">{group.name}</h3>
                <p class="text-gray-500 text-sm mt-1">{group.description}</p>
              </div>
              <svg class="w-5 h-5 text-gray-400 group-hover:text-gold shrink-0 ml-4 mt-0.5 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
