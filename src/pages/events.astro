---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Events" description="Upcoming and past events of the UST Applied Physics Society.">
  <section class="bg-aps-black text-white py-16 px-4 text-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-serif text-4xl font-bold mb-3" data-animate="fade-up">Events</h1>
      <p class="text-gray-400" data-animate="fade-up" data-animate-delay="120">Seminars, competitions, and activities</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-serif text-2xl font-bold text-aps-black mb-6" data-animate="fade-up">Upcoming Events</h2>
      <div class="bg-gray-50 rounded-xl p-12 text-center text-gray-400 border border-dashed border-gray-200" data-animate="fade-up" data-animate-delay="100">
        Add upcoming events here.
      </div>

      <h2 class="font-serif text-2xl font-bold text-aps-black mt-14 mb-6" data-animate="fade-up">Past Events</h2>
      <div class="bg-gray-50 rounded-xl p-12 text-center text-gray-400 border border-dashed border-gray-200" data-animate="fade-up" data-animate-delay="100">
        Past events will be listed here.
      </div>
    </div>
  </section>
</BaseLayout>
