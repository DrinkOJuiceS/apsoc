---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Officers" description="Meet the executive board of the UST Applied Physics Society.">
  <section class="bg-aps-black text-white py-16 px-4 text-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-serif text-4xl font-bold mb-3" data-animate="fade-up">Executive Board</h1>
      <p class="text-gray-400" data-animate="fade-up" data-animate-delay="120">Meet the team leading UST APS</p>
    </div>
  </section>

  <section class="py-24 px-4">
    <div class="max-w-4xl mx-auto text-center" data-animate="fade-up">
      <div class="inline-flex items-center justify-center w-20 h-20 bg-gold/10 rounded-full mb-6">
        <svg class="w-10 h-10 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </div>
      <h2 class="font-serif text-2xl font-bold text-aps-black mb-3">Roster Coming Soon</h2>
      <p class="text-gray-500 max-w-md mx-auto">
        The officer roster for the current academic year will be posted here. Check back soon!
      </p>
    </div>
  </section>
</BaseLayout>
