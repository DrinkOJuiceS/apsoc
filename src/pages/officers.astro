---
import BaseLayout from '../layouts/BaseLayout.astro';
import teams from '../data/teams.json';
---

<BaseLayout title="Teams" description="Meet the teams of the UST Applied Physics Society.">
  <section class="bg-aps-black text-white py-16 px-4 text-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-serif text-4xl font-bold mb-3" data-animate="fade-up">Our Teams</h1>
      <p class="text-gray-400" data-animate="fade-up" data-animate-delay="120">The teams leading UST APSoc</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {teams.map((team, i) => (
          <a
            href={`/teams/${team.slug}`}
            class="group p-8 bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 text-center block"
            data-animate="fade-up"
            data-animate-delay={String(i * 60)}
          >
            <div class="inline-flex items-center justify-center w-14 h-14 bg-gold/10 rounded-full mb-4 group-hover:bg-gold/20 transition-colors duration-200">
              <svg class="w-7 h-7 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="font-semibold text-aps-black text-base leading-snug">{team.name}</h3>
            <p class="text-gold text-sm mt-3 font-medium opacity-0 group-hover:opacity-100 transition-opacity duration-200">View team →</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
