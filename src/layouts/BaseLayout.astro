---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'University of Santo Tomas Applied Physics Society' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/logo.png" />
    <title>{title} | UST Applied Physics Society</title>
  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script>
  // Scroll-triggered reveal animations
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const delay = parseInt((entry.target as HTMLElement).dataset.animateDelay ?? '0');
          setTimeout(() => entry.target.classList.add('in-view'), delay);
        } else {
          entry.target.classList.remove('in-view');
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -48px 0px' }
  );

  document.querySelectorAll('[data-animate]').forEach((el) => revealObserver.observe(el));

  // Navbar scroll effect — handled in Navbar via window scroll event
  const header = document.querySelector('header');
  window.addEventListener('scroll', () => {
    header?.classList.toggle('is-scrolled', window.scrollY > 24);
  }, { passive: true });
</script>
